# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# App/Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
# Optional legacy fallback if your current local env already uses it.
AUTH_SECRET=""

# Cloudinary uploads
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_UPLOAD_FOLDER="clientforge/deliverables"

# Rate limiting (Upstash Redis)
# If omitted locally, ClientForge falls back to in-memory rate limiting.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# AI summaries
# If omitted locally, ClientForge falls back to deterministic summaries.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Password reset email (required in production)
# Without RESEND_API_KEY, reset links are never shown in the UI.
# In local dev, the reset link is logged to the terminal running `npm run dev`.
RESEND_API_KEY=""
PASSWORD_RESET_FROM_EMAIL="ClientForge <onboarding@resend.dev>"
